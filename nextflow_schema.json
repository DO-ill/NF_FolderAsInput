{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/nextflow_schema.json",
  "title": "Custom pipeline parameters",
  "description": "Converted to nf-schema compatible JSON Schema (draft 2020-12).",
  "type": "object",

  "$defs": {
    "custom_params": {
      "title": "Custom parameters",
      "type": "object",
      "properties": {
        "inputDir": {
          "type": "string",
          "title": "Input Directory",
          "description": "Input Directory",
          "format": "directory-path"
        }
      },
      "required": ["inputDir"],
      "additionalProperties": false
    }
  },

  "allOf": [
    { "$ref": "#/$defs/custom_params" }
  ]
}
